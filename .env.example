# Mantle Sepolia (default demo network)
MANTLE_SEPOLIA_RPC_URL=https://rpc.sepolia.mantle.xyz
MANTLE_PRIVATE_KEY=
MANTLE_EXPLORER_API_KEY=

# LLM provider for Hermes (OpenRouter recommended; Nous Portal optional)
OPENROUTER_API_KEY=
# NOUS_PORTAL_API_KEY=

# Tencent Cloud Hunyuan — deep AI security audit
# Get key at: https://console.cloud.tencent.com/hunyuan
TENCENT_HUNYUAN_API_KEY=

# Tencent Cloud COS — artifact storage + public verification URLs
# Credentials: https://console.cloud.tencent.com/cam/capi
# Bucket:      https://console.cloud.tencent.com/cos
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_BUCKET=
TENCENT_COS_REGION=ap-singapore

# Optional integrations
GITHUB_TOKEN=
