# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_token_here

# Optional: restrict the bot to a specific Telegram user ID (recommended for demos)
# ALLOWED_USER_ID=123456789

# Mantle Sepolia (forwarded to the deploy step)
MANTLE_SEPOLIA_RPC_URL=https://rpc.sepolia.mantle.xyz
MANTLE_PRIVATE_KEY=your_test_wallet_private_key_here
