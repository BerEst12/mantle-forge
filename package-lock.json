{
  "name": "mantle-forge",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "mantle-forge",
      "workspaces": [
        "installer",
        "tools/*"
      ],
      "engines": {
        "node": ">=20"
      }
    },
    "installer": {
      "name": "@mantle-forge/installer",
      "version": "0.0.0",
      "dependencies": {
        "@mantle-forge/cli-utils": "0.0.0"
      },
      "bin": {
        "mantle-forge": "cli.js"
      },
      "engines": {
        "node": ">=20"
      }
    },
    "node_modules/@mantle-forge/cli-utils": {
      "resolved": "tools/cli-utils",
      "link": true
    },
    "node_modules/@mantle-forge/installer": {
      "resolved": "installer",
      "link": true
    },
    "node_modules/@mantle-forge/mantle-audit": {
      "resolved": "tools/mantle-audit",
      "link": true
    },
    "node_modules/@mantle-forge/mantle-check": {
      "resolved": "tools/mantle-check",
      "link": true
    },
    "node_modules/@mantle-forge/mantle-cos-upload": {
      "resolved": "tools/mantle-cos-upload",
      "link": true
    },
    "node_modules/@mantle-forge/mantle-deploy": {
      "resolved": "tools/mantle-deploy",
      "link": true
    },
