{
  "name": "mantle-token-vault",
  "version": "1.0.0",
  "private": true,
  "description": "Mantle Sepolia-ready ERC-20 token vault",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:invariants": "hardhat test --grep \"invariant|fuzz\"",
    "test:forge": "forge test --match-contract TokenVault",
    "gas": "REPORT_GAS=true hardhat test",
    "deploy": "hardhat run scripts/deploy.ts --network mantleSepolia"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "@types/node": "^22.15.21",
    "hardhat": "^2.26.2",
    "hardhat-gas-reporter": "^2.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.3.0",
    "dotenv": "^16.6.1"
  }
}
